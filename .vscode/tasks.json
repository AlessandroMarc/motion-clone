{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: build-backend",
      "type": "npm",
      "script": "build",
      "path": "backend",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Debug: Motion Migration (with env)",
      "type": "shell",
      "command": "cd backend && npm run dev",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*waiting.*",
          "endsPattern": "^.*ready.*"
        }
      }
    }
  ]
}
