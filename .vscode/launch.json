{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Backend Server (tsx)",
      "program": "${workspaceFolder}/backend/src/index.ts",
      "runtimeArgs": ["--import", "tsx/esm"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "restart": true,
      "smartStep": false
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Motion Migration Script",
      "program": "${workspaceFolder}/backend/debug-migration.ts",
      "runtimeArgs": ["--import", "tsx/esm"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env.debug"
    }
  ]
}