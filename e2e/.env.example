# Integration test environment variables
# Copy this file to e2e/.env and fill in the values.
#
# IMPORTANT: e2e/.env is gitignored — never commit real credentials.

# Your Supabase project credentials (same as backend/.env.development.local)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The email of a Google account dedicated to E2E testing.
# This account must have signed in via Google at least once so it exists in Supabase.
E2E_TEST_USER_EMAIL=your-test-account@gmail.com
