# Copy this to .env.debug and fill in your actual values
# Only 2 variables needed:

# Your Motion API key from: https://app.usemotion.com/settings/integrations
MOTION_API_KEY=<your-motion-api-key-here>

# Your Supabase JWT (get from browser DevTools → Application → Local Storage → supabase.auth.token)
NEXTO_JWT=<your-supabase-jwt-here>